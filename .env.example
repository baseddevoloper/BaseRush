# Toggle real Base onchain execution
ENABLE_REAL_ONCHAIN=false

# Base RPC endpoint
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deploy signer private key (0x...)
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# TradeExecutor contract configuration
TRADE_EXECUTOR_ADDRESS=0x0000000000000000000000000000000000000000
TRADE_EXECUTOR_FUNCTION=executeTrade

# Signer used by backend to submit transactions (production: use KMS/HSM)
SERVER_SIGNER_PRIVATE_KEY=0xYOUR_SERVER_SIGNER_PRIVATE_KEY

# Async onchain confirmation policy
ONCHAIN_CONFIRMATIONS=1
ONCHAIN_CONFIRM_TIMEOUT_MS=120000

# Optional deploy/runtime params
TRADE_EXECUTOR_OWNER=
FEE_TREASURY_ADDRESS=
TRADE_FEE_BPS=100

# USDC deposit verification (Base)
USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_DEPOSIT_RECEIVER=
UNISWAP_V3_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481
AERODROME_ROUTER=0xcf77a3ba9a5ca399b7c97c74d54e5be8d5e8f9f3
AERODROME_FACTORY=0x420DD381b31aEf6683db6B902084cB0FFECe40Da
DEFAULT_UNI_POOL_FEE=500

# Optional ABI override (JSON array)
# TRADE_EXECUTOR_ABI_JSON=["function executeTrade(address token,uint8 side,uint256 amountUsdc,uint256 minOut,address recipient,bytes32 orderId)"]

# Optional args template for ABI mapping (JSON array)
# Available variables:
# $tokenAddress, $sideInt, $usdcAmount, $minOut, $recipient, $orderId, $tokenAmount
# TRADE_EXECUTOR_ARGS_TEMPLATE_JSON=["$tokenAddress","$sideInt","$usdcAmount","$minOut","$recipient","$orderId"]

# Mini app manifest (Farcaster/Base App)
APP_BASE_URL=https://baserush.app
FC_HOME_URL=https://baserush.app
FC_ICON_URL=https://baserush.app/icon.png
FC_IMAGE_URL=https://baserush.app/og.png
FC_SPLASH_IMAGE_URL=https://baserush.app/splash.png
FC_WEBHOOK_URL=https://baserush.app/api/farcaster/webhook
# notification routing mode: native or neynar
FC_NOTIFICATION_MODE=native
# required when FC_NOTIFICATION_MODE=neynar
FC_NEYNAR_EVENT_WEBHOOK_URL=
FC_FRAME_VERSION=1
FC_FRAME_NAME=BaseRush
FC_BUTTON_TITLE=Open BaseRush
FC_SPLASH_BG=#0B0F14
FC_SUBTITLE=Trade feed on Base
FC_DESCRIPTION=Track traders, see live activity, and execute USDC trades on Base with social insights
FC_SCREENSHOT_URLS=https://baserush.app/screenshots/home.png,https://baserush.app/screenshots/feed.png,https://baserush.app/screenshots/profile.png
FC_HERO_IMAGE_URL=https://baserush.app/hero.png
FC_TAGLINE=Trade social on Base
FC_OG_TITLE=BaseRush
FC_OG_DESCRIPTION=Social trading feed and copy tools on Base
FC_OG_IMAGE_URL=https://baserush.app/og.png
FC_NOINDEX=false
FC_PRIMARY_CATEGORY=finance
FC_TAGS=base,trading,socialfi,copytrade,defi

# Account association (Farcaster)
FC_ACCOUNT_ASSOC_HEADER=
FC_ACCOUNT_ASSOC_PAYLOAD=
FC_ACCOUNT_ASSOC_SIGNATURE=


# Base Builder Code attribution
BUILDER_CODE=bc_g19kvpy7
# Optional precomputed ERC-8021 data suffix (0x...)
BUILDER_DATA_SUFFIX=



# API hardening
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_TRADE_MAX=30
BODY_MAX_BYTES=262144

# Farcaster webhook verification (official Farcaster JFS format)
FC_WEBHOOK_REQUIRE_VERIFY=true
NEYNAR_API_KEY=

# Farcaster Quick Auth (JWT) verification for sensitive API actions
FC_AUTH_REQUIRED=true
FC_QUICK_AUTH_ORIGIN=https://auth.farcaster.xyz
# optional comma-separated override domains, e.g. baserush.app,staging.baserush.app
FC_AUTH_ALLOWED_DOMAINS=

# Block local private key signer on production unless explicitly allowed
ALLOW_LOCAL_SIGNER_IN_PROD=false

# Non-custodial user wallet router (wallet-direct mode)
USER_TRADE_ROUTER_ADDRESS=
USER_TRADE_ROUTER_OWNER=


# Uniswap v4 / Universal Router
UNISWAP_V4_UNIVERSAL_ROUTER=0x6ff5693b99212da76ad316178a184ab56d299b43
UNISWAP_PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
UNISWAP_V4_POOL_FEE=500
UNISWAP_V4_POOL_TICK_SPACING=10
UNISWAP_V4_POOL_HOOKS=0x0000000000000000000000000000000000000000
UNISWAP_V4_POOL_CURRENCY0=0x4200000000000000000000000000000000000006
UNISWAP_V4_POOL_CURRENCY1=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USER_ROUTER_V4_ENABLED=false

